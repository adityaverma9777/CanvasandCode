# =============================================================================
# Canvas2Code — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# =============================================================================

# ---------------- Backend (HuggingFace Space) --------------------------------
# Your live Socket.io server on Hugging Face.
# Format: https://<username>-<space-name>.hf.space
NEXT_PUBLIC_SOCKET_URL=https://edyxapi-canvas2code.hf.space

# ---------------- AI / Groq (Server-side only) --------------------------------
# Get your key from: https://console.groq.com/keys
# This is NOT prefixed with NEXT_PUBLIC — it stays server-side only.
GROQ_API_KEY=your_groq_api_key_here

# ---------------- HuggingFace (optional, for model APIs) ---------------------
# Only needed if you call HF Inference API directly from Next.js API routes.
HF_API_TOKEN=your_hf_api_token_here
